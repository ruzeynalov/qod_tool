import { test } from './fixtures/demo-mode';
test('block-level overflow walk', async ({ demoPage }) => {
  await demoPage.goto('/projects/demo-ecommerce', { waitUntil: 'networkidle' });
  await demoPage.waitForTimeout(2000); // give chart layout time
  const result = await demoPage.evaluate(() => {
    const html = document.documentElement;
    const ow = html.scrollWidth - html.clientWidth;
    const offenders: any[] = [];
    function walk(el: Element) {
      const r = (el as HTMLElement).getBoundingClientRect();
      const sw = (el as HTMLElement).scrollWidth;
      if (sw > html.clientWidth + 1 || r.right > html.clientWidth + 1) {
        offenders.push({
          path: el.tagName.toLowerCase() + (el.id ? '#' + el.id : ''),
          cls: typeof (el as HTMLElement).className === 'string'
            ? ((el as HTMLElement).className).slice(0, 80)
            : '',
          right: Math.round(r.right),
          width: Math.round(r.width),
          scrollW: sw,
        });
      }
      for (const c of el.children) walk(c);
    }
    walk(document.body);
    offenders.sort((a, b) => b.scrollW - a.scrollW);
    return { ow, vw: html.clientWidth, top: offenders.slice(0, 15) };
  });
  console.log('DBG_BLOCK:', JSON.stringify(result, null, 2));
});
