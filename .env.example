# ─── Database ───────────────────────────────────────
DATABASE_URL=postgresql://qod:qod_dev_password@localhost:5432/qod

# ─── Redis ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── API ────────────────────────────────────────────
PORT=4000
NODE_ENV=development
JWT_SECRET=change-me-in-production

# ─── Web ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production

# ─── Demo Mode ──────────────────────────────────────
# Set to true to auto-enable demo mode for new projects
QOD_DEMO_MODE=true

# ─── GitHub Connector (optional) ────────────────────
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_WEBHOOK_SECRET=

# ─── Jira Connector (optional) ─────────────────────
# JIRA_BASE_URL=
# JIRA_EMAIL=
# JIRA_API_TOKEN=

# ─── TestRail Connector (optional) ─────────────────
# TESTRAIL_BASE_URL=
# TESTRAIL_EMAIL=
# TESTRAIL_API_KEY=

# ─── Security ─────────────────────────────────────
CREDENTIALS_ENCRYPTION_KEY=generate-a-64-char-hex-key
CORS_ORIGIN=http://localhost:3000
POSTGRES_PASSWORD=qod_dev_password
